{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "target": "ES2022",
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "skipLibCheck": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictBindCallApply": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    // DTOs/entities are populated by class-validator/class-transformer/TypeORM
    // via reflection (not constructors), so enforcing field initialization here
    // would require noise-only `!` assertions. All type-safety-affecting strict
    // flags above remain enabled.
    "strictPropertyInitialization": false,
    // Friendlier to decorators + class-transformer (classic NestJS behaviour).
    "useDefineForClassFields": false,
    "forceConsistentCasingInFileNames": true,
    "noUnusedLocals": false,
    "noFallthroughCasesInSwitch": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "test", "dist"]
}
